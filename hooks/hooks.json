{
  "description": "Notifications for Claude Code permission prompts and finished responses.",
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/notify.js\" -Type permission",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/notify.js\" -Type finish",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
